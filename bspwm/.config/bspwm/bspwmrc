#!/bin/sh

# --- 1. LIMPIEZA DE PROCESOS ---
# Matar todo lo anterior para evitar procesos zombie o bloqueos de bus.
killall -9 sxhkd polybar picom dunst 2>/dev/null

# Esperar que la memoria de la Polybar esté liberada antes lanzar.
while pgrep -u $UID -x polybar >/dev/null; do sleep 1; done

# --- 2. ENTORNO Y MONITORES ---
if command -v dbus-update-activation-environment >/dev/null; then
    dbus-update-activation-environment --all
fi

bspc monitor -d 1 2 3 4 5 6 7 8

# --- 3. CONFIGURACIÓN DE VENTANAS ---
bspc config border_width         1
bspc config window_gap           5
bspc config split_ratio          0.50
bspc config auto_alternate       true
bspc config layout               tiled
bspc config focused_border_color "#00ff00"
bspc config normal_border_color  "#1a1b26"

# --- 4. ARRANQUE DE INFRAESTRUCTURA VISUAL ---
xsetroot -cursor_name left_ptr &
sxhkd &
picom --config ~/.config/picom/picom.conf &
feh --bg-fill ~/dotfiles/wallpapers/wall-01.webp &

# Lanzamos script y asegurar de que sea ejecutable.
if [ -x "$HOME/.config/polybar/launch.sh" ]; then
    $HOME/.config/polybar/launch.sh &
else
    # Fallback si el script falla: Lanzamiento directo desvinculado
    polybar main -c ~/.config/polybar/config.ini >/dev/null 2>&1 & disown
fi

# --- 5. REGLAS ---
bspc rule -a * manage=on
bspc rule -a Kitty desktop='^1' follow=on
